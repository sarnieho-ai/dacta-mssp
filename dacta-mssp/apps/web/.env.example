# ── Jira Cloud API ──
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_INSTANCE=your-site.atlassian.net
JIRA_CLOUD_ID=your-cloud-id
JIRA_TEAM_ID=your-team-id

# ── Elasticsearch / Elastic SIEM ──
ELASTIC_URL=https://your-cluster.es.region.aws.found.io
ELASTIC_API_KEY=your-elastic-api-key

# ── Supabase (server-side) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── LLM API Keys (Multi-Model Investigation Engine) ──
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ── CrowdStrike Falcon Intel API ──
CROWDSTRIKE_CLIENT_ID=your-crowdstrike-client-id
CROWDSTRIKE_CLIENT_SECRET=your-crowdstrike-client-secret
CROWDSTRIKE_BASE_URL=https://api.us-2.crowdstrike.com
